{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": ""
  },
  "AppSettings": {
    "JwtSecret": "",
    "JwtIssuer": "javaline.commercial",
    "JwtAudience": "javaline.commercial",
    "JwtExpirationMinutes": "15",
    "CorsOrigins": "http://localhost:5173,http://localhost:4173"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  }
}
