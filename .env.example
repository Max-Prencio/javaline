# ─────────────────────────────────────────────────────────
# FRONTEND — set these in Vercel → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────

# URL of your deployed FastAPI backend (no trailing slash)
VITE_API_URL=https://your-backend.railway.app

# ─────────────────────────────────────────────────────────
# BACKEND — set these in Railway → Service → Variables
# ─────────────────────────────────────────────────────────

# PostgreSQL connection string (Railway injects this automatically when you add a Postgres plugin)
DATABASE_URL=postgresql://postgres:password@host:5432/javaline

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-32-byte-random-hex-string

# Comma-separated list of allowed frontend origins (your Vercel URL)
CORS_ORIGINS=https://your-app.vercel.app,https://yourdomain.com

# Token expiry in minutes (default 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional: OpenAI for AI Assistant feature
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
