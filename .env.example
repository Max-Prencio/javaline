# ─────────────────────────────────────────────────────────
# Copia este archivo como .env y completa los valores
# cp .env.example .env
# ─────────────────────────────────────────────────────────

# REQUERIDO: Contraseña de PostgreSQL
# Genera una segura: openssl rand -base64 24
POSTGRES_PASSWORD=cambia_esto_por_una_password_segura

# REQUERIDO: Secreto JWT (mínimo 32 caracteres)
# Genera uno: openssl rand -hex 32
JWT_SECRET=cambia_esto_por_un_secreto_de_al_menos_32_chars

# OPCIONAL: OpenAI para el módulo AI Assistant
OPENAI_API_KEY=sk-...
